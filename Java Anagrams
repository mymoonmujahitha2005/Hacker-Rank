import java.util.Scanner;

public class Solution {

        static boolean isAnagram(String a, String b) {
        // 1. If lengths are different, they cannot be anagrams
        if (a.length() != b.length()) {
            return false;
        }
        
        // 2. Convert to lowercase for case-insensitive comparison
        a = a.toLowerCase();
        b = b.toLowerCase();
        
        // 3. Create a frequency array for the 26 letters of the alphabet
        int[] frequencies = new int[26];
        
        // 4. Iterate through the strings
        for (int i = 0; i < a.length(); i++) {
            // Increment for string a
            frequencies[a.charAt(i) - 'a']++;
            // Decrement for string b
            frequencies[b.charAt(i) - 'a']--;
        }
        
        // 5. If they are anagrams, every value in the array must be 0
        for (int count : frequencies) {
            if (count != 0) {
                return false;
            }
        }
        
        return true;
    }


    public static void main(String[] args) {
    
        Scanner scan = new Scanner(System.in);
        String a = scan.next();
        String b = scan.next();
        scan.close();
        boolean ret = isAnagram(a, b);
        System.out.println( (ret) ? "Anagrams" : "Not Anagrams" );
    }
}
