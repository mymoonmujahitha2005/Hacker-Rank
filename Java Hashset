import java.io.*;
import java.util.*;
import java.text.*;
import java.math.*;
import java.util.regex.*;

public class Solution {

 public static void main(String[] args) {
        Scanner s = new Scanner(System.in);
        int t = s.nextInt();
        String [] pair_left = new String[t];
        String [] pair_right = new String[t];
        
        for (int i = 0; i < t; i++) {
            pair_left[i] = s.next();
            pair_right[i] = s.next();
        }

    // 1. Use a HashSet with an initial capacity of T to avoid resizing overhead
    HashSet<String> set = new HashSet<>(t);
    StringBuilder output = new StringBuilder();

    // 2. Iterate through the pairs
    for (int i = 0; i < t; i++) {
        // 3. Combine the strings with a space delimiter
        set.add(pair_left[i] + " " + pair_right[i]);
        
        // 4. Append the current size to our output buffer
        output.append(set.size()).append("\n");
    }

    // 5. Print the entire result at once
    System.out.print(output);

    }
}
